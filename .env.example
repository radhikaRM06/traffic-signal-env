# ─── LLM API Configuration ───────────────────────────────────────────────────
# Required by inference.py

# API endpoint for the LLM (OpenAI-compatible)
API_BASE_URL=https://api.openai.com/v1

# Model identifier to use for inference
MODEL_NAME=gpt-4o-mini

# Your Hugging Face / OpenAI API key
HF_TOKEN=your_api_key_here

# ─── Environment Configuration ───────────────────────────────────────────────
# Optional — override defaults

# Which task to run (server-side default)
# Options: single_intersection_easy | arterial_corridor_medium | urban_grid_hard
TRAFFIC_TASK=single_intersection_easy

# Random seed for reproducibility
TRAFFIC_SEED=42

# Where the environment server is running (for inference.py)
TRAFFIC_HOST=http://localhost:7860
